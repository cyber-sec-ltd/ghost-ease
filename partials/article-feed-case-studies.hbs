<section id="casestudies" style="margin-top: 4rem;" class="post-wrapper">

            <header class="featured-header topic-header">
                <h2 class="featured-title topic-name">Case Studies</h2>
            </header>
            {{#get "posts" filter="tag:case-studies" limit="4" include="tags" as |featured|}}
            {{#if featured}}
            <div class="cs-topic-article-feed">
            {{#foreach featured}}
                <article class="{{post_class}}">
                    {{#if feature_image}}
                    <figure class="post-media">
                    <div class="u-placeholder same-height horizontal">
                        <a class="post-image-link" href="{{url}}">
                            
                                <img class="post-image u-object-fit" src="{{img_url feature_image size="l"}}" alt="{{title}}">
                            
                        </a>
                    </div>
                    </figure>
                    {{/if}}
                    <header class="post-header">
                        <h2 class="post-title">
                            <a style="color: #0e337c;"class="post-title-link" href="{{url}}">{{title}}</a>
                        </h2>
                        <div style="margin-top: 15px;margin-bottom: 15px;"> {{og_description}}</div>
                        <div class="cs-excerpt"><a href="{{url}}">{{excerpt}}</a></div>
                     </header>
                    
                </article>
            {{/foreach}}         
            </div>
            <!-- <a style="margin-top: 2rem;" class="post-tag tag-blog" href="/blog/" title="Our Techie Blogs">Read more blogs →</a> -->
            {{/if}}
            {{/get}}
        </section>